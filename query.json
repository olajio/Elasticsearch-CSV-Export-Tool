{
  "bool": {
    "filter": [
      {
        "range": {
          "@timestamp": {
            "format": "strict_date_optional_time",
            "gte": "2025-12-24T05:00:00.000Z",
            "lte": "2026-03-24T15:22:59.972Z"
          }
        }
      },
      {
        "match_phrase": {
          "kubernetes.namespace": "hs-sql-console"
        }
      },
      {
        "exists": {
          "field": "user.name"
        }
      },
      {
        "match_phrase": {
          "cloud.account.name": "hedgeserv-app-prd"
        }
      }
    ],
    "must_not": [
      {
        "match_phrase": {
          "user.name": "yatanasov"
        }
      }
    ]
  }
}
